<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp"
    android:background="@drawable/rounded_bottom_sheet_background"> 
    
    <!-- Title Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        
        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/options"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>
            
        <TextView
            android:id="@+id/tvSheetSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_an_action"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <!-- Move Option (Customer Only) -->
    <LinearLayout
        android:id="@+id/optionMove"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_move_to_inbox"
            app:tint="#616161"
            android:contentDescription="@string/move_to_folder"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/move_to_folder"
            android:textSize="16sp"
            android:textColor="#424242"
            android:layout_marginStart="24dp"/>
    </LinearLayout>
    
    <!-- Edit Option -->
    <LinearLayout
        android:id="@+id/optionEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            app:tint="#424242"
            android:contentDescription="@string/edit_details"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_details"
            android:textSize="16sp"
            android:textColor="#424242"
            android:layout_marginStart="24dp"/>
    </LinearLayout>

    <!-- Delete Option -->
    <LinearLayout
        android:id="@+id/optionDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete_forever"
            app:tint="#D32F2F"
            android:contentDescription="@string/delete"/> <!-- Red for Danger -->
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/delete"
            android:textSize="16sp"
            android:textColor="#D32F2F"
            android:layout_marginStart="24dp"/>
    </LinearLayout>

</LinearLayout>
